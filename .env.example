# ══════════════════════════════════════════════
# TechMart - Docker Production Environment
# Copy file này thành .env rồi điền giá trị thực
# Dùng với: docker compose -f docker-compose.prod.yml up -d
# ══════════════════════════════════════════════

# Database
DB_ROOT_PASSWORD=techmart123
DB_NAME=mobile_shop
DB_USER=techmart_user
DB_PASSWORD=

# JWT
JWT_SECRET=techmart_jwt_secret_key_2026

# CORS & Frontend URL
CORS_ORIGIN=http://localhost
FRONTEND_URL=http://localhost

# Frontend API URL (được bake vào lúc build)
VITE_API_URL=http://localhost/api

# VNPay (bỏ trống nếu không dùng)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:5001/api/payment/vnpay/return

# Email SMTP (bỏ trống nếu không dùng)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
