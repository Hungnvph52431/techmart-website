# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3307
DB_NAME=mobile_shop
DB_USER=techmart_user
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=techmart_jwt_secret_key_2026
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# File Upload
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880

# VNPay Sandbox - Đăng ký tại https://sandbox.vnpayment.vn/
# Vào "Quản lý website" -> lấy TMN Code và Secret Key
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_RETURN_URL=http://localhost:5001/api/payment/vnpay/return
FRONTEND_URL=http://localhost:5173

# Email SMTP - Dùng Gmail App Password
# Hướng dẫn: Bật 2FA Gmail > Tạo App Password tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM_NAME=TechMart
