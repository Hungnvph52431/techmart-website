{
  "name": "techmart-backend",
  "version": "1.0.0",
  "description": "Backend API for TechMart phone store using Clean Architecture",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migration:create": "ts-node src/infrastructure/database/migrations/create-migration.ts",
    "migration:run": "ts-node src/infrastructure/database/migrations/run-migrations.ts"
  },
  "keywords": [
    "techmart",
    "ecommerce",
    "clean-architecture"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.3",
    "qs": "^6.15.0",
    "react-chartjs-2": "^5.3.1",
    "react-hook-form": "^7.71.2",
    "uuid": "^9.0.1",
    "vnpay": "^2.4.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^7.0.11",
    "@types/qs": "^6.15.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
